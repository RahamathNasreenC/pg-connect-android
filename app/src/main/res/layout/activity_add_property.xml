<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F6FA"
    tools:context=".AddPropertyActivity">

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:padding="20dp"
        android:scrollbars="none"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Top Header Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="22dp"
                app:cardElevation="10dp"
                app:cardBackgroundColor="#FFFFFF">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="18dp">

                    <Button
                        android:id="@+id/btnBack"
                        android:layout_width="70dp"
                        android:layout_height="42dp"
                        android:text="Back"
                        android:textStyle="bold"
                        android:textAllCaps="false"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#2563EB"
                        android:elevation="6dp"
                        android:layout_alignParentStart="true"
                        android:layout_centerVertical="true"/>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerInParent="true"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Add New Property"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="#111827"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Fill details to add a listing"
                            android:textSize="13sp"
                            android:textColor="#6B7280"
                            android:layout_marginTop="3dp"/>

                    </LinearLayout>

                </RelativeLayout>

            </androidx.cardview.widget.CardView>


            <!-- Property Details Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="18dp"
                app:cardCornerRadius="22dp"
                app:cardElevation="10dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Property Details"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#111827"
                        android:layout_marginBottom="12dp"/>

                    <EditText
                        android:id="@+id/etTitle"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:hint="Property Title"
                        android:padding="14dp"
                        android:textColor="#111827"
                        android:textColorHint="#9CA3AF"
                        android:background="@drawable/rounded_edittext"/>

                    <EditText
                        android:id="@+id/etLocation"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:hint="Location"
                        android:padding="14dp"
                        android:textColor="#111827"
                        android:textColorHint="#9CA3AF"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/rounded_edittext"/>

                    <EditText
                        android:id="@+id/etRoomType"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:hint="Room Type"
                        android:padding="14dp"
                        android:textColor="#111827"
                        android:textColorHint="#9CA3AF"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/rounded_edittext"/>

                    <EditText
                        android:id="@+id/etRent"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:hint="Monthly Rent"
                        android:inputType="number"
                        android:padding="14dp"
                        android:textColor="#111827"
                        android:textColorHint="#9CA3AF"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/rounded_edittext"/>

                    <EditText
                        android:id="@+id/etDescription"
                        android:layout_width="match_parent"
                        android:layout_height="130dp"
                        android:hint="Description"
                        android:padding="14dp"
                        android:gravity="top"
                        android:textColor="#111827"
                        android:textColorHint="#9CA3AF"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/rounded_edittext"/>

                </LinearLayout>

            </androidx.cardview.widget.CardView>


            <!-- Rooms & Contact Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="18dp"
                app:cardCornerRadius="22dp"
                app:cardElevation="10dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rooms &amp; Contact"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#111827"
                        android:layout_marginBottom="12dp"/>

                    <EditText
                        android:id="@+id/etAvailableRooms"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:hint="Available Rooms"
                        android:inputType="number"
                        android:padding="14dp"
                        android:textColor="#111827"
                        android:textColorHint="#9CA3AF"
                        android:background="@drawable/rounded_edittext"/>

                    <EditText
                        android:id="@+id/etContactNumber"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:hint="Contact Number"
                        android:inputType="phone"
                        android:padding="14dp"
                        android:textColor="#111827"
                        android:textColorHint="#9CA3AF"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/rounded_edittext"/>

                </LinearLayout>

            </androidx.cardview.widget.CardView>


            <!-- Bed Image Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="18dp"
                app:cardCornerRadius="22dp"
                app:cardElevation="10dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bed Type Image"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#111827"
                        android:layout_marginBottom="12dp"/>

                    <ImageView
                        android:id="@+id/ivBedImage"
                        android:layout_width="match_parent"
                        android:layout_height="180dp"
                        android:background="#F3F4F6"
                        android:scaleType="centerCrop"
                        android:layout_marginBottom="12dp"/>

                    <Button
                        android:id="@+id/btnSelectBedImage"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:text="Select Bed Image"
                        android:textStyle="bold"
                        android:textAllCaps="false"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#2563EB"
                        android:elevation="8dp"/>

                </LinearLayout>

            </androidx.cardview.widget.CardView>


            <!-- Amenities Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="18dp"
                app:cardCornerRadius="22dp"
                app:cardElevation="10dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Amenities"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#111827"
                        android:layout_marginBottom="10dp"/>

                    <CheckBox
                        android:id="@+id/cbWifi"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Wifi"
                        android:textColor="#111827"
                        android:textSize="15sp"/>

                    <CheckBox
                        android:id="@+id/cbFood"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Food"
                        android:textColor="#111827"
                        android:textSize="15sp"/>

                    <CheckBox
                        android:id="@+id/cbAC"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AC"
                        android:textColor="#111827"
                        android:textSize="15sp"/>

                    <CheckBox
                        android:id="@+id/cbLaundry"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Laundry"
                        android:textColor="#111827"
                        android:textSize="15sp"/>

                    <CheckBox
                        android:id="@+id/cbSecurity"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Security"
                        android:textColor="#111827"
                        android:textSize="15sp"/>

                </LinearLayout>

            </androidx.cardview.widget.CardView>


            <!-- Property Image Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="18dp"
                app:cardCornerRadius="22dp"
                app:cardElevation="10dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Property Image"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#111827"
                        android:layout_marginBottom="12dp"/>

                    <ImageView
                        android:id="@+id/ivPropertyImage"
                        android:layout_width="match_parent"
                        android:layout_height="180dp"
                        android:background="#F3F4F6"
                        android:scaleType="centerCrop"
                        android:layout_marginBottom="12dp"/>

                    <Button
                        android:id="@+id/btnSelectImage"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:text="Select Image"
                        android:textStyle="bold"
                        android:textAllCaps="false"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#2563EB"
                        android:elevation="8dp"/>

                </LinearLayout>

            </androidx.cardview.widget.CardView>


            <!-- Add Property Button -->
            <Button
                android:id="@+id/btnAddPropertySave"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Add Property"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="17sp"
                android:backgroundTint="#2563EB"
                android:elevation="12dp"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="25dp"/>

        </LinearLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
